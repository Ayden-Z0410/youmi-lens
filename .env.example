# =============================================================================
# Youmi Lens — copy to .env and fill values. Vite only exposes vars prefixed VITE_.
# =============================================================================

# --- Cloud login & data (Mac 公测：建议始终配置，便于发给别人试用) ---
# With BOTH URL and anon key set, the app shows login (email magic link + Google; Apple optional).
# Enable Email + OAuth providers under Supabase Dashboard → Authentication → Providers.
# Leave VITE_SUPABASE_ANON_KEY unset to land on the setup page (local-only or add keys later).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# --- AI / transcription (生产构建：前端固定走后端代理；勿把用户 OpenAI key 打进公测包) ---
# Production / split deploy: public HTTPS origin of your AI proxy server (no trailing slash).
# The app calls `${VITE_API_BASE_URL}/api/transcribe`, `/api/summarize`, etc. (see getAiApiBase).
# Leave unset in local dev: Vite dev server proxies /api to the local Node AI server.
# **Tauri Mac trial (tauri build):** set VITE_API_BASE_URL in .env.production — required; see docs/tauri-desktop-trial-p0.md
# VITE_API_BASE_URL=https://your-ai-server.example.com

# --- Dev-only toggles (不参与生产逻辑或生产 UI) ---
# Local dev: default AI path is client OpenAI unless you set this to opt into backend proxy like prod.
# VITE_USE_AI_BACKEND=true
# Dev: show “Developer: OpenAI API key” panel (set to false to hide). Never shown in import.meta.env.PROD.
# VITE_SHOW_DEV_AI_KEY=false
# Optional: legacy browser key for dev when not using backend (never for production distribution).
# VITE_OPENAI_API_KEY=
# Local A/B only: `true` = in Youmi AI mode, skip live slice MediaRecorder (main recording unchanged).
# VITE_EXPERIMENT_SKIP_YOUMI_LIVE_SLICE=true

# --- Tauri desktop auth (magic link / OAuth return path) ---
# In `tauri dev`, magic-link redirect uses: http://localhost:5173/tauri-auth-callback → forwards to lecturecompanion://
# Add BOTH to Supabase → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:5173/tauri-auth-callback
#   lecturecompanion://auth-callback
# Packaged Mac app (production build): default redirect is lecturecompanion://auth-callback unless you set:
# VITE_AUTH_BRIDGE_ORIGIN=https://your-static-host.example.com
# (that host must serve the same SPA so /tauri-auth-callback exists)

# --- Optional product flags ---
# Show “Continue with Apple” on login (V1.1; requires Apple + Supabase configuration).
# VITE_SHOW_APPLE_SIGNIN=true

# --- Server-side only (npm run dev:server or your hosted API — not bundled into the Vite app) ---
# Real hosted Youmi AI (production-like): set enterprise key and keep stub OFF.
# DASHSCOPE_API_KEY=sk-...
# ENABLE_STUB_AI=false
# Youmi AI (hosted): Alibaba Model Studio — DASHSCOPE_API_KEY (Beijing region API key from Model Studio console).
# Text: OpenAI-compatible chat (Qwen) at dashscope.aliyuncs.com/compatible-mode/v1
# Cloud recording speech: Paraformer async file ASR (HTTPS URL only per official API — server uses Supabase signed URLs).
# DASHSCOPE_API_KEY=sk-...
# Optional text model (default qwen-turbo):
# YUMI_QWEN_CHAT_MODEL=qwen-turbo
# Optional Paraformer model (default paraformer-v2):
# YUMI_PARAFORMER_MODEL=paraformer-v2
# Comma-separated language hints for lecture ASR (default zh,en):
# YUMI_PARAFORMER_LANGUAGE_HINTS=zh,en
# Signed URL lifetime for DashScope to fetch audio from Supabase (seconds, default 7200):
# YUMI_STORAGE_SIGNED_URL_SEC=7200
# Paraformer async task poll interval in ms (default 250; lower = faster completion, more API calls):
# YUMI_PARAFORMER_POLL_INTERVAL_MS=500
# Optional: POST /api/transcribe with raw multipart file — Paraformer cannot accept uploads; set this + OpenAI for Whisper-only buffer path:
# YUMI_HOSTED_TRANSCRIBE_IMPL=openai_fallback
# OPENAI_API_KEY=sk-...
# Local development/demo fallback for hosted Youmi AI when enterprise key is not configured:
# ENABLE_STUB_AI=true
# AI_SERVER_PORT=3847
# Required for POST /api/process-recording (cloud recordings: signed URL → Paraformer → Qwen summaries, write DB):
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# Strongly recommended (server only; never VITE_*): service_role key so the AI server can persist ai_status/transcript/summaries reliably after JWT ownership checks. Dashboard → Settings → API.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# --- Product AI mode (dev) ---
# When true, the web app behaves like production: no local dev API key UI; cloud recordings use POST /api/process-recording only.
# VITE_PRODUCT_AI_MODE=true
