{
  "name": "lecture-companion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:full",
    "dev:web": "vite",
    "dev:desktop": "tauri dev",
    "dev:desktop:full": "concurrently -k -n server,desktop -c blue,green \"npm run dev:server\" \"npm run dev:desktop\"",
    "dev:server": "node server/index.mjs",
    "dev:full": "concurrently -k -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "build": "tsc -b && vite build",
    "tauri": "tauri",
    "build:desktop": "tauri build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "extract:youmi-y": "python3 scripts/extract-youmi-y-mark.py"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@supabase/supabase-js": "^2.101.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "fflate": "^0.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "multer": "^2.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
